// TSConfig for modules that run in Node.js environment
{
  "include": [
    "vite.config.*",
    "playwright.config.*",
    "eslint.config.*"
  ],
  "exclude": ["e2e"],
  "compilerOptions": {
    "target": "ES2022",
    "module": "preserve",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "skipLibCheck": true,
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo"
  }
}
